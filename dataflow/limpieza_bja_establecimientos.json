{
	"name": "limpieza_bja_establecimientos",
	"properties": {
		"folder": {
			"name": "BJA"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bja_establecimientos_salud",
						"type": "DatasetReference"
					},
					"name": "limpiezaEstablecimientosBJA"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_bja_establecimientos",
						"type": "DatasetReference"
					},
					"name": "sinkSilverEstablecimientosBJA"
				}
			],
			"transformations": [
				{
					"name": "limpiarEstado"
				}
			],
			"scriptLines": [
				"source(output(",
				"          establecimiento_id as string,",
				"          codigo_snis as string,",
				"          nombre as string,",
				"          tipo as string,",
				"          nivel_atencion as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          red_salud as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> limpiezaEstablecimientosBJA",
				"limpiezaEstablecimientosBJA derive(estado = upper(trim(estado))) ~> limpiarEstado",
				"limpiarEstado sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkSilverEstablecimientosBJA"
			]
		}
	}
}