{
	"name": "limpieza_sup_inscripciones",
	"properties": {
		"folder": {
			"name": "SUP"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "sup_inscripciones",
						"type": "DatasetReference"
					},
					"name": "limpiezaInscripcionesSUP"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_sup_inscripciones",
						"type": "DatasetReference"
					},
					"name": "sinkSilverInscripcionesSUP"
				}
			],
			"transformations": [
				{
					"name": "limpiarCIpaso1"
				},
				{
					"name": "limpiarCIpaso2"
				},
				{
					"name": "marcarCIyEstado"
				}
			],
			"scriptLines": [
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> limpiezaInscripcionesSUP",
				"limpiezaInscripcionesSUP derive(ci_paso1 = upper(trim(replace(replace(ci_beneficiaria, '-', ''), ' ', '')))) ~> limpiarCIpaso1",
				"limpiarCIpaso1 derive(ci_beneficiaria_limpio = iif(regexMatch(ci_paso1, '^[A-Z]{2}[0-9]+$'), concat(regexExtract(ci_paso1, '([0-9]+)'), regexExtract(ci_paso1, '^([A-Z]{2})')), ci_paso1)) ~> limpiarCIpaso2",
				"limpiarCIpaso2 derive(ci_calidad = iif(regexMatch(ci_beneficiaria_limpio, '^[0-9]+$'), 'INCOMPLETO_SIN_DEPTO', 'OK'),",
				"          estado = upper(trim(estado))) ~> marcarCIyEstado",
				"marcarCIyEstado sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkSilverInscripcionesSUP"
			]
		}
	}
}