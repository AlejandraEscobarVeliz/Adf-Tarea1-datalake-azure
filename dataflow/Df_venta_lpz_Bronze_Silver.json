{
	"name": "Df_venta_lpz_Bronze_Silver",
	"properties": {
		"folder": {
			"name": "Bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Ventas_Lpz_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Ventas_scz_limpio_csv",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID_Venta as string,",
				"          Fecha_Venta as string,",
				"          Producto as string,",
				"          Cant as string,",
				"          PrecioUnit as string,",
				"          Sucursal as string,",
				"          Vendedor as string,",
				"          NombreCliente as string,",
				"          EmailCliente as string,",
				"          MetodoPago as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 select(mapColumn(",
				"          id_venta = ID_Venta,",
				"          fecha_venta = Fecha_Venta,",
				"          producto = Producto,",
				"          cantidad = Cant,",
				"          precio_unitario = PrecioUnit,",
				"          sucursal = Sucursal,",
				"          vendedor = Vendedor,",
				"          nombre_cliente = NombreCliente,",
				"          email_cliente = EmailCliente,",
				"          metodo_pago = MetodoPago",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(id_venta = trim(id_venta),",
				"          fecha_venta = trim(fecha_venta),",
				"          producto = trim(producto),",
				"          cantidad = trim(cantidad),",
				"          precio_unitario = trim(precio_unitario),",
				"          sucursal = trim(sucursal),",
				"          vendedor = trim(vendedor),",
				"          nombre_cliente = trim(nombre_cliente),",
				"          email_cliente = trim(email_cliente),",
				"          metodo_pago = trim(metodo_pago)) ~> derivedColumn1",
				"derivedColumn1 derive(sucursal = iif(\r",
				"    in(['LPZ','La Paz','LP','la paz','LA PAZ','Lapaz','L.P.'],sucursal),'La Paz',sucursal\r",
				"),",
				"          canal = 'Sucursal') ~> derivedColumn2",
				"derivedColumn2 derive(fecha_venta = coalesce(\r",
				"toDate(fecha_venta,'yyyy-MM-dd'),\r",
				"toDate(fecha_venta,'dd-MM-yyyy'),\r",
				"toDate(fecha_venta,'MM-dd-yyyy'),\r",
				"toDate(fecha_venta,'dd/MM/yyyy'),\r",
				"toDate(fecha_venta,'yyyy/MM/dd'),\r",
				"toDate(fecha_venta,'dd/MMM/yyyy'),\r",
				"toDate(fecha_venta,'dd-MMM-yyyy'),\r",
				"toDate(fecha_venta,\"dd 'de' MMMM 'de' yyyy\"),\r",
				"toDate(fecha_venta,'MMMM dd, yyyy')\r",
				")) ~> derivedColumn3",
				"derivedColumn3 derive(cantidad = toInteger(cantidad),",
				"          precio_unitario = toFloat(regexReplace(toString(precio_unitario), '[^0-9.]', ''))) ~> derivedColumn4",
				"derivedColumn4 derive(producto = initCap(trim(regexReplace(producto, '\\\\s+', ' ')))) ~> derivedColumn5",
				"derivedColumn5 filter(cantidad>0 && !isNull(precio_unitario) && !isNull(fecha_venta)) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['ventas_lpz_limpio.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}